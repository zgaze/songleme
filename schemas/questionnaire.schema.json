{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Songleme Questionnaire Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "startQuestionId", "resultNode", "questions"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "minLength": 1 },
    "startQuestionId": { "$ref": "#/definitions/id" },
    "resultNode": { "$ref": "#/definitions/id" },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/question" }
    }
  },
  "definitions": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
    },
    "size": {
      "type": "string",
      "enum": ["xl", "lg", "md", "sm"]
    },
    "next": {
      "type": "string",
      "minLength": 1
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "label"],
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "size": { "$ref": "#/definitions/size" },
        "next": { "$ref": "#/definitions/next" },
        "min": {
          "type": "number"
        },
        "max": {
          "type": ["number", "null"]
        }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "type", "options"],
      "properties": {
        "id": { "$ref": "#/definitions/id" },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["single", "multi"]
        },
        "defaultNext": { "$ref": "#/definitions/next" },
        "max": {
          "type": "integer",
          "minimum": 1
        },
        "allowCustom": { "type": "boolean" },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/option" }
        }
      }
    }
  }
}
