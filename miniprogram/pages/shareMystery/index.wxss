.share-mystery {
  min-height: 100vh;
  padding: 72rpx 42rpx calc(64rpx + env(safe-area-inset-bottom));
  background: #f6f9ff;
  box-sizing: border-box;
}

.share-mystery__panel {
  min-height: 680rpx;
  padding: 72rpx 42rpx 56rpx;
  border-radius: 40rpx;
  background: #ffd7e5;
  box-sizing: border-box;
  text-align: center;
  box-shadow:
    20rpx 24rpx 48rpx rgba(23, 28, 33, 0.065),
    inset -10rpx -12rpx 24rpx rgba(116, 51, 77, 0.1),
    inset 10rpx 10rpx 24rpx rgba(255, 255, 255, 0.76);
}

.share-mystery__gift {
  position: relative;
  width: 212rpx;
  height: 188rpx;
  margin: 0 auto 48rpx;
  border-radius: 42rpx 42rpx 34rpx 34rpx;
  background: #fffdf8;
  box-shadow:
    inset -8rpx -9rpx 18rpx rgba(23, 28, 33, 0.05),
    inset 8rpx 8rpx 18rpx rgba(255, 255, 255, 0.82);
}

.share-mystery__gift::before,
.share-mystery__gift::after {
  position: absolute;
  top: -24rpx;
  width: 88rpx;
  height: 64rpx;
  border-radius: 50% 50% 42% 42%;
  background: #cfe8ff;
  content: "";
}

.share-mystery__gift::before {
  left: 22rpx;
  transform: rotate(-16deg);
}

.share-mystery__gift::after {
  right: 22rpx;
  transform: rotate(16deg);
}

.share-mystery__ribbon {
  position: absolute;
  top: 0;
  left: 88rpx;
  width: 36rpx;
  height: 188rpx;
  background: #c9efd9;
}

.share-mystery__kicker {
  display: block;
  color: rgba(32, 40, 51, 0.48);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
}

.share-mystery__title {
  display: block;
  margin-top: 16rpx;
  color: #202833;
  font-size: 42rpx;
  font-weight: 600;
  line-height: 1.28;
}

.share-mystery__summary {
  display: block;
  margin-top: 30rpx;
  color: rgba(32, 40, 51, 0.66);
  font-size: 27rpx;
  font-weight: 400;
  line-height: 1.55;
}

.share-mystery__pairing {
  display: block;
  margin-top: 24rpx;
  color: rgba(32, 40, 51, 0.52);
  font-size: 24rpx;
  line-height: 1.45;
}

.share-mystery__button {
  width: 560rpx;
  height: 104rpx;
  margin: 42rpx auto 0;
  padding: 0;
  border-radius: 999rpx;
  background: #cfe8ff;
  color: #202833;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 104rpx;
  box-shadow:
    16rpx 18rpx 38rpx rgba(23, 28, 33, 0.055),
    inset -7rpx -8rpx 16rpx rgba(23, 28, 33, 0.06),
    inset 8rpx 8rpx 18rpx rgba(255, 255, 255, 0.76);
}

.share-mystery__button::after {
  border: 0;
}
