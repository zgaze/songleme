.share-mystery {
  min-height: 100vh;
  padding: 72rpx 42rpx calc(64rpx + env(safe-area-inset-bottom));
  background: var(--bg);
  box-sizing: border-box;
}

.share-mystery__panel {
  min-height: 680rpx;
  padding: 72rpx 42rpx 56rpx;
  border-radius: var(--r-lg);
  background: var(--rose);
  box-sizing: border-box;
  text-align: center;
  box-shadow: var(--out-lg), var(--ins-rose);
}

.share-mystery__gift {
  position: relative;
  width: 212rpx;
  height: 188rpx;
  margin: 0 auto 48rpx;
  border-radius: var(--r-md) var(--r-md) var(--r-sm) var(--r-sm);
  background: var(--surface-solid);
  box-shadow: var(--ins-neutral);
}

.share-mystery__gift::before,
.share-mystery__gift::after {
  position: absolute;
  top: -24rpx;
  width: 88rpx;
  height: 64rpx;
  border-radius: 50% 50% 42% 42%;
  background: var(--blue);
  content: "";
}

.share-mystery__gift::before {
  left: 22rpx;
  transform: rotate(-16deg);
}

.share-mystery__gift::after {
  right: 22rpx;
  transform: rotate(16deg);
}

.share-mystery__ribbon {
  position: absolute;
  top: 0;
  left: 88rpx;
  width: 36rpx;
  height: 188rpx;
  background: var(--mint);
}

.share-mystery__kicker {
  display: block;
  color: var(--on-rose);
  font-size: var(--fs-label);
  font-weight: 600;
  line-height: 1.2;
}

.share-mystery__title {
  display: block;
  margin-top: 16rpx;
  color: var(--text);
  font-size: var(--fs-title);
  font-weight: 600;
  line-height: 1.28;
}

.share-mystery__summary {
  display: block;
  margin-top: 30rpx;
  color: var(--text-2);
  font-size: var(--fs-body);
  font-weight: 400;
  line-height: 1.55;
}

.share-mystery__pairing {
  display: block;
  margin-top: 24rpx;
  color: var(--text-3);
  font-size: var(--fs-label);
  line-height: 1.45;
}

.share-mystery__button {
  width: 560rpx;
  height: 104rpx;
  margin: 42rpx auto 0;
  padding: 0;
  border-radius: var(--r-pill);
  background: var(--blue);
  color: var(--on-blue);
  font-size: var(--fs-h2);
  font-weight: 600;
  line-height: 104rpx;
  box-shadow: var(--out-md), var(--ins-blue);
}

.share-mystery__button::after {
  border: 0;
}
