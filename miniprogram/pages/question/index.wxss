.question {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 26rpx calc(132rpx + env(safe-area-inset-bottom));
  background: var(--bg);
  box-sizing: border-box;
}

.question__header {
  width: 100%;
  text-align: center;
}

.question__title {
  display: block;
  color: var(--text);
  font-size: var(--fs-title);
  font-weight: 600;
  line-height: 1.28;
  text-shadow: 0 8rpx 18rpx rgba(74, 48, 60, 0.08);
}

.question__options {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  align-content: center;
  gap: 18rpx;
  width: 100%;
  flex: 1;
  margin-top: 28rpx;
  padding: 4rpx 6rpx 20rpx;
  box-sizing: border-box;
}

.option {
  position: relative;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  background: var(--blue);
  color: var(--on-blue);
  font-size: var(--fs-label);
  font-weight: 500;
  text-align: center;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: var(--out-md), var(--ins-blue);
  transition: transform 120ms ease, box-shadow 120ms ease;
}

.option__label {
  display: block;
  max-width: 100%;
  line-height: 1.22;
  overflow-wrap: break-word;
}

.option:active,
.option--active {
  transform: translateY(3rpx) scale(0.96);
  border-color: rgba(255, 255, 255, 0.72);
  color: var(--text);
  box-shadow: var(--ins-press);
}

.option__mark {
  position: absolute;
  top: 22rpx;
  right: 26rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: var(--r-pill);
  background: rgba(42, 33, 38, 0.55);
  box-shadow: 0 0 0 7rpx rgba(255, 255, 255, 0.58);
}

.option--size-xl {
  width: 210rpx;
  height: 210rpx;
  font-size: var(--fs-h2);
}

.option--size-lg {
  width: 182rpx;
  height: 182rpx;
  font-size: var(--fs-body);
}

.option--size-md {
  width: 154rpx;
  height: 154rpx;
  font-size: var(--fs-sm);
}

.option--size-sm {
  width: 128rpx;
  height: 128rpx;
  font-size: var(--fs-label);
}

.option--shape-0 {
  background: var(--blue);
  border-radius: 51% 49% 48% 52% / 50% 48% 52% 50%;
}

.option--shape-1 {
  background: var(--rose);
  border-radius: 49% 51% 53% 47% / 52% 48% 50% 50%;
  color: var(--on-rose);
  box-shadow: var(--out-md), var(--ins-rose);
}

.option--shape-2 {
  background: var(--gold);
  border-radius: 52% 48% 49% 51% / 49% 52% 48% 51%;
  color: var(--on-gold);
  box-shadow: var(--out-md), var(--ins-gold);
}

.option--shape-3 {
  background: var(--mint);
  border-radius: 48% 52% 50% 50% / 51% 47% 53% 49%;
  color: var(--on-mint);
  box-shadow: var(--out-md), var(--ins-mint);
}

.option--shape-4 {
  background: var(--blue-soft);
  border-radius: 50% 50% 52% 48% / 48% 52% 49% 51%;
}

.option--shape-5 {
  background: var(--rose-soft);
  border-radius: 53% 47% 48% 52% / 50% 49% 51% 50%;
  color: var(--on-rose);
  box-shadow: var(--out-md), var(--ins-rose);
}

.question__footer {
  position: fixed;
  right: 44rpx;
  bottom: calc(44rpx + env(safe-area-inset-bottom));
  left: 44rpx;
  display: flex;
  justify-content: center;
  gap: 22rpx;
}

.ghost-button,
.dark-button {
  min-width: 218rpx;
  height: 82rpx;
  border-radius: var(--r-pill);
  font-size: var(--fs-sm);
  font-weight: 600;
  line-height: 82rpx;
}

.ghost-button {
  background: var(--surface);
  color: var(--text-2);
  box-shadow: var(--out-md), var(--ins-neutral);
}

.dark-button {
  background: var(--rose);
  color: var(--on-rose);
  box-shadow: var(--out-md), var(--ins-rose);
}

.ghost-button::after,
.dark-button::after {
  border: 0;
}
