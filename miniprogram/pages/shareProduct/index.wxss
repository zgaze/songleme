.share-product {
  min-height: 100vh;
  padding: 54rpx 36rpx calc(58rpx + env(safe-area-inset-bottom));
  background: var(--bg);
  box-sizing: border-box;
}

.share-product__card {
  overflow: hidden;
  border-radius: var(--r-md);
  background: var(--surface);
  box-shadow: var(--out-lg), var(--ins-neutral);
}

.share-product__media {
  position: relative;
  width: 100%;
  height: 520rpx;
  overflow: hidden;
  background: var(--blue);
}

.share-product__image,
.share-product__placeholder {
  width: 100%;
  height: 100%;
  display: block;
}

.share-product__placeholder::before {
  position: absolute;
  right: 52rpx;
  bottom: 48rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.38);
  content: "";
}

.share-product__body {
  padding: 32rpx 34rpx 38rpx;
}

.share-product__label {
  display: block;
  color: var(--text-3);
  font-size: var(--fs-label);
  font-weight: 600;
  line-height: 1.3;
}

.share-product__name {
  display: block;
  margin-top: 12rpx;
  color: var(--text);
  font-size: var(--fs-h1);
  font-weight: 600;
  line-height: 1.28;
}

.share-product__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.share-product__tag {
  max-width: 180rpx;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: var(--r-pill);
  background: var(--rose);
  color: var(--on-rose);
  box-sizing: border-box;
  font-size: var(--fs-cap);
  font-weight: 500;
  line-height: 42rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.share-product__reason {
  display: block;
  margin-top: 24rpx;
  color: var(--text-2);
  font-size: var(--fs-body);
  font-weight: 400;
  line-height: 1.52;
}

.share-product__button {
  width: 560rpx;
  height: 104rpx;
  margin: 42rpx auto 0;
  padding: 0;
  border-radius: var(--r-pill);
  background: var(--mint);
  color: var(--on-mint);
  font-size: var(--fs-h2);
  font-weight: 600;
  line-height: 104rpx;
  box-shadow: var(--out-md), var(--ins-mint);
}

.share-product__button::after {
  border: 0;
}
