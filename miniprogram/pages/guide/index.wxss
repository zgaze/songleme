.guide {
  min-height: 100vh;
  padding: 34rpx 28rpx calc(54rpx + env(safe-area-inset-bottom));
  background: var(--bg);
  box-sizing: border-box;
}

.guide__head {
  padding: 8rpx 8rpx 16rpx;
}

.guide__kicker {
  display: block;
  color: var(--text-3);
  font-size: var(--fs-cap);
  font-weight: 600;
  line-height: 1.2;
}

.guide__title {
  display: block;
  margin-top: 14rpx;
  color: var(--text);
  font-size: var(--fs-title);
  font-weight: 600;
  line-height: 1.24;
}

.guide__channels {
  position: sticky;
  top: 0;
  z-index: 5;
  margin: 0 -28rpx;
  padding: 10rpx 0 18rpx;
  background: var(--bg-veil);
}

.guide__channel-row,
.guide__article-row {
  display: flex;
  padding: 0 28rpx;
  white-space: nowrap;
}

.guide__channel {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 124rpx;
  height: 62rpx;
  margin: 0 16rpx 0 0;
  padding: 0 28rpx;
  border-radius: var(--r-pill);
  color: var(--text-2);
  font-size: var(--fs-label);
  font-weight: 600;
  line-height: 62rpx;
  box-shadow: var(--out-sm), var(--ins-neutral);
}

.guide__channel::after,
.guide-article-card::after {
  border: 0;
}

.guide__channel--blue {
  background: var(--blue-soft);
}

.guide__channel--pink {
  background: var(--rose-soft);
}

.guide__channel--green {
  background: var(--mint-soft);
}

.guide__channel--apricot {
  background: var(--gold-soft);
}

.guide__channel--active {
  color: var(--text);
  transform: translateY(-2rpx);
  box-shadow: var(--out-md), var(--ins-neutral);
}

.guide__feature {
  margin-top: 10rpx;
  padding: 30rpx 32rpx;
  border-radius: var(--r-md);
  box-shadow: var(--out-md), var(--ins-neutral);
}

.guide__feature--blue {
  background: var(--blue);
  box-shadow: var(--out-md), var(--ins-blue);
}

.guide__feature--pink {
  background: var(--rose);
  box-shadow: var(--out-md), var(--ins-rose);
}

.guide__feature--green {
  background: var(--mint);
  box-shadow: var(--out-md), var(--ins-mint);
}

.guide__feature--apricot {
  background: var(--gold);
  box-shadow: var(--out-md), var(--ins-gold);
}

.guide__feature-title {
  display: block;
  color: var(--text);
  font-size: var(--fs-h1);
  font-weight: 600;
  line-height: 1.25;
}

.guide__feature-copy {
  display: block;
  margin-top: 12rpx;
  color: var(--text-2);
  font-size: var(--fs-label);
  font-weight: 400;
  line-height: 1.46;
}

.guide__note {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: var(--r-md);
  background: var(--surface);
  box-shadow: var(--out-sm), var(--ins-neutral);
}

.guide__note-label {
  flex: 0 0 auto;
  margin-right: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: var(--r-pill);
  background: var(--gold-soft);
  color: var(--on-gold);
  font-size: var(--fs-cap);
  font-weight: 600;
  line-height: 1.2;
}

.guide__note-copy {
  flex: 1;
  min-width: 0;
  color: var(--text-2);
  font-size: var(--fs-label);
  font-weight: 400;
  line-height: 1.5;
}

.guide__articles {
  margin: 22rpx -28rpx 0;
  padding-bottom: 4rpx;
}

.guide-article-card {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  width: 368rpx;
  min-height: 176rpx;
  margin-right: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: var(--r-md);
  text-align: left;
  box-sizing: border-box;
  box-shadow: var(--out-sm), var(--ins-neutral);
}

.guide-article-card--sky {
  background: var(--blue-soft);
}

.guide-article-card--rose {
  background: var(--rose-soft);
}

.guide-article-card--leaf {
  background: var(--mint-soft);
}

.guide-article-card--apricot {
  background: var(--gold-soft);
}

.guide-article-card--active {
  transform: translateY(-2rpx);
  box-shadow: var(--out-md), var(--ins-neutral);
}

.guide-article-card__title {
  display: block;
  color: var(--text);
  font-size: var(--fs-body);
  font-weight: 600;
  line-height: 1.28;
  white-space: normal;
}

.guide-article-card__summary {
  display: block;
  flex: 1;
  margin-top: 10rpx;
  color: var(--text-3);
  font-size: var(--fs-cap);
  font-weight: 400;
  line-height: 1.42;
  white-space: normal;
}

.guide-article-card__time {
  display: block;
  margin-top: 14rpx;
  color: var(--text-3);
  font-size: var(--fs-cap);
  font-weight: 600;
  line-height: 1.2;
}

.guide-article {
  margin-top: 24rpx;
  padding: 6rpx 4rpx 0;
}

.guide-article__meta {
  display: flex;
  flex-wrap: wrap;
  color: var(--text-3);
  font-size: var(--fs-cap);
  font-weight: 600;
  line-height: 1.3;
}

.guide-article__meta text {
  margin: 0 12rpx 8rpx 0;
}

.guide-article__title {
  display: block;
  margin-top: 16rpx;
  color: var(--text);
  font-size: var(--fs-h1);
  font-weight: 650;
  line-height: 1.25;
}

.guide-article__subtitle {
  display: block;
  margin-top: 12rpx;
  color: var(--text-2);
  font-size: var(--fs-label);
  font-weight: 400;
  line-height: 1.5;
}

.guide-article__tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.guide-article__tag {
  margin: 0 12rpx 12rpx 0;
  padding: 8rpx 16rpx;
  border-radius: var(--r-pill);
  background: var(--surface);
  color: var(--text-3);
  font-size: var(--fs-cap);
  font-weight: 600;
  line-height: 1.2;
}

.guide-blocks {
  margin-top: 10rpx;
}

.guide-block {
  margin-top: 20rpx;
  box-sizing: border-box;
}

.guide-block--heading {
  margin-top: 32rpx;
  color: var(--text);
  font-size: var(--fs-h2);
  font-weight: 650;
  line-height: 1.28;
}

.guide-block--paragraph {
  color: var(--text-2);
  font-size: var(--fs-sm);
  font-weight: 400;
  line-height: 1.66;
}

.guide-block--tip,
.guide-block--list,
.guide-block--checklist,
.guide-block--compare,
.guide-block--gift-refs {
  padding: 24rpx;
  border-radius: var(--r-md);
  background: var(--surface);
  box-shadow: var(--out-sm), var(--ins-neutral);
}

.guide-block--tip {
  background: var(--gold-soft);
}

.guide-block__label {
  display: inline-flex;
  margin-bottom: 12rpx;
  padding: 7rpx 14rpx;
  border-radius: var(--r-pill);
  background: var(--gold-soft);
  color: var(--on-gold);
  font-size: var(--fs-cap);
  font-weight: 700;
  line-height: 1.2;
}

.guide-block__title {
  display: block;
  color: var(--text);
  font-size: var(--fs-body);
  font-weight: 650;
  line-height: 1.3;
}

.guide-block__copy {
  display: block;
  margin-top: 12rpx;
  color: var(--text-2);
  font-size: var(--fs-label);
  font-weight: 400;
  line-height: 1.55;
}

.guide-list,
.guide-checklist,
.guide-compare,
.guide-gift-refs {
  margin-top: 16rpx;
}

.guide-list__item,
.guide-checklist__item {
  display: flex;
  align-items: flex-start;
  margin-top: 14rpx;
  color: var(--text-2);
  font-size: var(--fs-label);
  font-weight: 400;
  line-height: 1.48;
}

.guide-list__dot {
  flex: 0 0 auto;
  width: 10rpx;
  height: 10rpx;
  margin: 14rpx 16rpx 0 2rpx;
  border-radius: 50%;
  background: var(--on-blue);
}

.guide-checklist__mark {
  flex: 0 0 auto;
  width: 34rpx;
  height: 34rpx;
  margin-right: 14rpx;
  border-radius: 50%;
  background: var(--mint);
  color: var(--on-mint);
  font-size: var(--fs-cap);
  font-weight: 700;
  line-height: 34rpx;
  text-align: center;
}

.guide-compare__item,
.guide-gift-ref {
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: var(--r-sm);
  background: var(--surface-solid);
}

.guide-compare__label,
.guide-gift-ref__name {
  display: block;
  color: var(--text);
  font-size: var(--fs-label);
  font-weight: 650;
  line-height: 1.25;
}

.guide-compare__good,
.guide-gift-ref__note {
  display: block;
  margin-top: 8rpx;
  color: var(--text-2);
  font-size: var(--fs-cap);
  font-weight: 500;
  line-height: 1.42;
}

.guide-compare__caution {
  display: block;
  margin-top: 6rpx;
  color: var(--text-3);
  font-size: var(--fs-cap);
  font-weight: 400;
  line-height: 1.45;
}
