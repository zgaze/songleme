.home {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 72rpx 48rpx calc(176rpx + env(safe-area-inset-bottom));
  background: var(--bg);
  box-sizing: border-box;
}

.home__action {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 26rpx;
  padding-bottom: 88rpx;
}

.home-button {
  width: 560rpx;
  height: 112rpx;
  margin: 0;
  padding: 0;
  border-radius: var(--r-pill);
  color: var(--text);
  font-size: var(--fs-h1);
  font-weight: 600;
  line-height: 112rpx;
  box-shadow: var(--out-md), var(--ins-rose);
  transition: transform 120ms ease, box-shadow 120ms ease;
}

.home-button--primary {
  background: var(--rose);
  color: var(--on-rose);
  box-shadow: var(--out-md), var(--ins-rose);
}

.home-button--guide {
  background: var(--blue);
  color: var(--on-blue);
  box-shadow: var(--out-md), var(--ins-blue);
}

.home-button:active {
  transform: scale(0.975);
  box-shadow: var(--out-sm), var(--ins-press);
}

.home-button::after {
  border: 0;
}
