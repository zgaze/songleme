.contacts {
  min-height: 100vh;
  padding: 56rpx 32rpx 200rpx;
  background: var(--bg);
  box-sizing: border-box;
}

.contacts__head {
  padding: 0 8rpx;
}

.contacts__title {
  display: block;
  color: var(--text);
  font-size: var(--fs-display);
  font-weight: 800;
  line-height: 1.2;
}

.contacts__sub {
  display: block;
  margin-top: 12rpx;
  color: var(--text-3);
  font-size: var(--fs-sm);
}

.contacts__hint {
  margin-top: 60rpx;
  text-align: center;
  color: var(--text-3);
  font-size: var(--fs-sm);
}

.contacts__list {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.contacts__empty {
  margin-top: 40rpx;
  text-align: center;
  color: var(--text-3);
  font-size: var(--fs-sm);
}

/* clay tile（复用 profile__row 模式） */
.contact-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 120rpx;
  padding: 0 32rpx;
  border-radius: var(--r-lg);
  background: var(--surface);
  box-shadow: var(--out-md), var(--ins-neutral);
  transition: transform 120ms ease, box-shadow 120ms ease;
}

.contact-card:active {
  transform: scale(0.985);
  box-shadow: var(--out-sm), var(--ins-press);
}

.contact-card__main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
  padding-right: 24rpx;
}

.contact-card__name {
  color: var(--text);
  font-size: var(--fs-body);
  font-weight: 600;
  line-height: 1.2;
}

.contact-card__summary {
  color: var(--text-3);
  font-size: var(--fs-label);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.contact-card__del {
  flex: 0 0 auto;
  padding: 12rpx 24rpx;
  border-radius: var(--r-pill);
  color: var(--on-rose);
  font-size: var(--fs-label);
  font-weight: 600;
  background: var(--rose-soft);
  box-shadow: var(--out-sm), var(--ins-rose);
}

.contact-card__del:active {
  transform: scale(0.96);
  box-shadow: var(--ins-press);
}

.contact-card__arrow {
  flex: 0 0 auto;
  color: var(--text-3);
  font-size: var(--fs-title);
  line-height: 1;
}

.contacts__actions {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 22rpx;
}

.ghost-button,
.dark-button {
  min-width: 360rpx;
  height: 82rpx;
  border-radius: var(--r-pill);
  font-size: var(--fs-sm);
  font-weight: 600;
  line-height: 82rpx;
}

.ghost-button {
  background: var(--surface);
  color: var(--text-2);
  box-shadow: var(--out-md), var(--ins-neutral);
}

.dark-button {
  background: var(--rose);
  color: var(--on-rose);
  box-shadow: var(--out-md), var(--ins-rose);
}

.ghost-button::after,
.dark-button::after {
  border: 0;
}
