.result {
  min-height: 100vh;
  padding: 26rpx 28rpx calc(42rpx + env(safe-area-inset-bottom));
  background: #f6f9ff;
  box-sizing: border-box;
}

.result__loading {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  color: #41474e;
  font-size: 30rpx;
  font-weight: 700;
}

.result__loading-ball {
  width: 132rpx;
  height: 132rpx;
  border-radius: 52% 48% 50% 50% / 48% 54% 46% 52%;
  background: #ffb0cd;
  box-shadow:
    18rpx 22rpx 44rpx rgba(23, 28, 33, 0.08),
    inset -10rpx -12rpx 22rpx rgba(110, 51, 76, 0.18),
    inset 9rpx 9rpx 20rpx rgba(255, 255, 255, 0.72);
}

.result__summary {
  min-height: 128rpx;
  padding: 24rpx 26rpx;
  border-radius: 30rpx;
  background: #cde5ff;
  box-shadow:
    14rpx 18rpx 38rpx rgba(23, 28, 33, 0.07),
    inset -9rpx -10rpx 22rpx rgba(48, 98, 138, 0.12),
    inset 9rpx 9rpx 20rpx rgba(255, 255, 255, 0.76);
  box-sizing: border-box;
}

.result__summary-head {
  display: flex;
  align-items: center;
}

.result__summary-copy {
  flex: 1;
  min-width: 0;
}

.result__title {
  display: block;
  color: #171c21;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.42;
}

.result__pairing-line {
  display: block;
  margin-top: 10rpx;
  color: rgba(23, 28, 33, 0.62);
  font-size: 21rpx;
  font-weight: 500;
  line-height: 1.32;
}

.result__sticky-actions {
  position: sticky;
  top: 12rpx;
  z-index: 8;
  display: flex;
  gap: 14rpx;
  justify-content: flex-end;
  padding: 14rpx 0 12rpx;
  background: rgba(246, 249, 255, 0.82);
}

.result__action {
  width: 126rpx;
  height: 48rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #30628a;
  box-sizing: border-box;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 48rpx;
  box-shadow:
    8rpx 9rpx 18rpx rgba(23, 28, 33, 0.05),
    inset -5rpx -5rpx 12rpx rgba(48, 98, 138, 0.1),
    inset 5rpx 5rpx 12rpx rgba(255, 255, 255, 0.86);
}

.result__action--primary {
  background: #ffd9e4;
  color: #74334d;
}

.result__action--mystery {
  background: #cfe8ff;
  color: #30628a;
}

.result__action::after {
  border: 0;
}

.result__goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  box-sizing: border-box;
}

.result__candidate-slot {
  width: calc((100% - 28rpx) / 3);
  margin-bottom: 16rpx;
}
