.result {
  min-height: 100vh;
  padding: 26rpx 28rpx calc(42rpx + env(safe-area-inset-bottom));
  background: var(--bg);
  box-sizing: border-box;
}

.result__loading {
  min-height: 60vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  color: var(--text-2);
  font-size: var(--fs-h2);
  font-weight: 700;
}

.result__loading-ball {
  width: 132rpx;
  height: 132rpx;
  border-radius: 52% 48% 50% 50% / 48% 54% 46% 52%;
  background: var(--rose-deep);
  box-shadow: var(--out-lg), var(--ins-rose);
}

.result__summary {
  min-height: 128rpx;
  padding: 24rpx 26rpx;
  border-radius: var(--r-md);
  background: var(--blue);
  box-shadow: var(--out-md), var(--ins-blue);
  box-sizing: border-box;
}

.result__summary-head {
  display: flex;
  align-items: center;
}

.result__summary-copy {
  flex: 1;
  min-width: 0;
}

.result__title {
  display: block;
  color: var(--text);
  font-size: var(--fs-body);
  font-weight: 600;
  line-height: 1.42;
}

.result__pairing-line {
  display: block;
  margin-top: 10rpx;
  color: var(--text-3);
  font-size: var(--fs-label);
  font-weight: 500;
  line-height: 1.32;
}

.result__sticky-actions {
  position: sticky;
  top: 12rpx;
  z-index: 8;
  display: flex;
  gap: 14rpx;
  justify-content: flex-end;
  padding: 14rpx 0 12rpx;
  background: var(--bg-veil);
}

.result__action {
  width: 126rpx;
  height: 48rpx;
  margin: 0;
  padding: 0;
  border-radius: var(--r-pill);
  background: var(--surface);
  color: var(--on-blue);
  box-sizing: border-box;
  font-size: var(--fs-cap);
  font-weight: 700;
  line-height: 48rpx;
  box-shadow: var(--out-sm), var(--ins-neutral);
}

.result__action--primary {
  background: var(--rose);
  color: var(--on-rose);
  box-shadow: var(--out-sm), var(--ins-rose);
}

.result__action--mystery {
  background: var(--blue);
  color: var(--on-blue);
  box-shadow: var(--out-sm), var(--ins-blue);
}

.result__action::after {
  border: 0;
}

.result__goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  box-sizing: border-box;
}

.result__candidate-slot {
  width: calc((100% - 28rpx) / 3);
  margin-bottom: 16rpx;
}
