<view class="page result">
  <view wx:if="{{loading}}" class="result__loading">
    <view class="result__loading-ball"></view>
    <text>正在挑选</text>
  </view>

  <block wx:else>
    <view class="result__summary">
      <view class="result__summary-head">
        <view class="result__summary-copy">
          <text class="result__title">{{result.summary}}</text>
          <text wx:if="{{result.pairingText}}" class="result__pairing-line">建议搭配“{{result.pairingText}}”</text>
        </view>
      </view>
    </view>

    <view class="result__sticky-actions">
      <button
        class="result__action result__action--mystery"
        open-type="share"
        data-share-type="mystery"
      >
        神秘礼物
      </button>
      <button class="result__action result__action--primary" bindtap="aiPick">AI帮选</button>
    </view>

    <view class="result__goods-list">
      <view wx:for="{{result.candidates}}" wx:key="id" class="result__candidate-slot">
        <result-card item="{{item}}" />
      </view>
    </view>
  </block>
</view>
