.card-edit {
  min-height: 100vh;
  padding: 30rpx 28rpx calc(54rpx + env(safe-area-inset-bottom));
  background: var(--bg);
  box-sizing: border-box;
}

/* ---- 预览区 ---------------------------------------------- */

.card-stage {
  display: flex;
  justify-content: center;
  padding: 12rpx 0 8rpx;
}

.card-canvas {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 100%;
  max-width: 480rpx;
  height: 640rpx;
  padding: 52rpx 44rpx;
  border-radius: var(--r-lg);
  overflow: hidden;
  box-sizing: border-box;
  box-shadow: var(--out-md), var(--ins-neutral);
}

.card-canvas__accent {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 14rpx;
  border-radius: var(--r-pill);
}

.card-canvas__salu {
  display: block;
  font-size: var(--fs-h1);
  font-weight: 650;
  line-height: 1.3;
}

.card-canvas__bless {
  display: block;
  margin-top: 22rpx;
  font-size: var(--fs-body);
  font-weight: 400;
  line-height: 1.56;
  opacity: 0.88;
}

.card-canvas__sign {
  display: block;
  margin-top: 34rpx;
  font-size: var(--fs-label);
  font-weight: 600;
  text-align: right;
  opacity: 0.7;
}

/* ---- 选择区 ---------------------------------------------- */

.card-edit__section {
  margin-top: 28rpx;
}

.card-edit__label {
  display: block;
  margin: 0 4rpx 14rpx;
  color: var(--text-3);
  font-size: var(--fs-label);
  font-weight: 600;
  line-height: 1.2;
}

.card-edit__row-scroll {
  margin: 0 -28rpx;
}

.card-edit__row {
  display: flex;
  padding: 0 28rpx;
  white-space: nowrap;
}

.card-tpl {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 124rpx;
  height: 64rpx;
  margin-right: 16rpx;
  padding: 0 28rpx;
  border-radius: var(--r-pill);
  background: var(--surface);
  color: var(--text-2);
  font-size: var(--fs-label);
  font-weight: 600;
  line-height: 64rpx;
  box-shadow: var(--out-sm), var(--ins-neutral);
}

.card-tpl--active {
  color: var(--text);
  transform: translateY(-2rpx);
  box-shadow: var(--out-md), var(--ins-neutral);
}

.card-edit__palettes {
  display: flex;
  align-items: center;
  padding: 0 4rpx;
}

.card-swatch {
  width: 76rpx;
  height: 76rpx;
  margin-right: 22rpx;
  border-radius: 50%;
  box-shadow: var(--out-sm), var(--ins-neutral);
  transition: transform 120ms ease, box-shadow 120ms ease;
}

.card-swatch--active {
  transform: scale(1.08);
  box-shadow: var(--out-md), var(--ins-press);
}

/* ---- 表单 ------------------------------------------------ */

.card-edit__form {
  margin-top: 30rpx;
}

.card-field {
  margin-top: 22rpx;
}

.card-field__head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 0 4rpx 12rpx;
}

.card-field__label {
  color: var(--text-2);
  font-size: var(--fs-label);
  font-weight: 600;
  line-height: 1.2;
}

.card-field__count {
  color: var(--text-3);
  font-size: var(--fs-cap);
  font-weight: 600;
  line-height: 1.2;
}

.card-field__input,
.card-field__textarea {
  width: 100%;
  padding: 24rpx 26rpx;
  border-radius: var(--r-md);
  background: var(--surface);
  color: var(--text);
  font-size: var(--fs-body);
  line-height: 1.5;
  box-sizing: border-box;
  box-shadow: var(--ins-press);
}

.card-field__textarea {
  min-height: 132rpx;
}

/* ---- 底部操作 -------------------------------------------- */

.card-edit__actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 22rpx;
  margin-top: 40rpx;
}

.card-btn {
  width: 560rpx;
  height: 104rpx;
  margin: 0;
  padding: 0;
  border-radius: var(--r-pill);
  font-size: var(--fs-h1);
  font-weight: 600;
  line-height: 104rpx;
  transition: transform 120ms ease, box-shadow 120ms ease;
}

.card-btn::after {
  border: 0;
}

.card-btn--save {
  background: var(--rose);
  color: var(--on-rose);
  box-shadow: var(--out-md), var(--ins-rose);
}

.card-btn--share {
  background: var(--mint);
  color: var(--on-mint);
  box-shadow: var(--out-md), var(--ins-mint);
}

.card-btn:active {
  transform: scale(0.975);
  box-shadow: var(--out-sm), var(--ins-press);
}

/* ---- 离屏导出 canvas（移出视口，不可用 display:none）------ */

.card-export-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
}

/* ---- 动画（与 card 画廊一致，每页 WXSS 独立定义）---------- */

@keyframes card-float {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-12rpx);
  }
  100% {
    transform: translateY(0);
  }
}

@keyframes card-shine {
  0% {
    transform: translateX(-30rpx);
    opacity: 0.55;
  }
  50% {
    transform: translateX(30rpx);
    opacity: 1;
  }
  100% {
    transform: translateX(-30rpx);
    opacity: 0.55;
  }
}

.anim-float {
  animation: card-float 3.2s ease-in-out infinite;
}

.anim-shine .card-canvas__accent {
  animation: card-shine 2.8s ease-in-out infinite;
}
