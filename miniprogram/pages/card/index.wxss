.card-gallery {
  min-height: 100vh;
  padding: 34rpx 28rpx calc(54rpx + env(safe-area-inset-bottom));
  background: var(--bg);
  box-sizing: border-box;
}

.card-gallery__head {
  padding: 8rpx 8rpx 16rpx;
}

.card-gallery__kicker {
  display: block;
  color: var(--text-3);
  font-size: var(--fs-cap);
  font-weight: 600;
  line-height: 1.2;
}

.card-gallery__title {
  display: block;
  margin-top: 14rpx;
  color: var(--text);
  font-size: var(--fs-title);
  font-weight: 600;
  line-height: 1.24;
}

.card-gallery__list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  margin-top: 18rpx;
}

.card-preview {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 380rpx;
  padding: 44rpx 40rpx;
  border-radius: var(--r-lg);
  overflow: hidden;
  box-sizing: border-box;
  box-shadow: var(--out-md), var(--ins-neutral);
}

.card-preview::after {
  border: 0;
}

.card-preview__accent {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 14rpx;
  border-radius: var(--r-pill);
}

.card-preview__name {
  display: block;
  font-size: var(--fs-h1);
  font-weight: 650;
  line-height: 1.25;
}

.card-preview__bless {
  display: block;
  margin-top: 18rpx;
  font-size: var(--fs-body);
  font-weight: 400;
  line-height: 1.5;
  opacity: 0.86;
}

.card-preview__sign {
  display: block;
  margin-top: 28rpx;
  font-size: var(--fs-label);
  font-weight: 600;
  text-align: right;
  opacity: 0.7;
}

/* ---- 动画（首个引入 @keyframes 的页面）-------------------- */

@keyframes card-float {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-12rpx);
  }
  100% {
    transform: translateY(0);
  }
}

@keyframes card-shine {
  0% {
    transform: translateX(-30rpx);
    opacity: 0.55;
  }
  50% {
    transform: translateX(30rpx);
    opacity: 1;
  }
  100% {
    transform: translateX(-30rpx);
    opacity: 0.55;
  }
}

.anim-float {
  animation: card-float 3.2s ease-in-out infinite;
}

.anim-shine .card-preview__accent {
  animation: card-shine 2.8s ease-in-out infinite;
}
