.profile {
  min-height: 100vh;
  padding: 56rpx 32rpx 180rpx;
  background: var(--bg);
  box-sizing: border-box;
}

.profile__header {
  padding: 0 8rpx;
}

.profile__title {
  color: var(--text);
  font-size: var(--fs-display);
  font-weight: 800;
  line-height: 1.2;
}

/* Items separated by whitespace, each its own clay tile
   (per design spec: lists use whitespace, not divider lines). */
.profile__list {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.profile__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 108rpx;
  padding: 0 32rpx;
  border-radius: var(--r-lg);
  background: var(--surface);
  color: var(--text);
  font-size: var(--fs-body);
  font-weight: 600;
  box-shadow: var(--out-md), var(--ins-neutral);
  transition: transform 120ms ease, box-shadow 120ms ease;
}

.profile__row:active {
  transform: scale(0.985);
  box-shadow: var(--out-sm), var(--ins-press);
}

.profile__arrow {
  color: var(--text-3);
  font-size: var(--fs-title);
  line-height: 1;
}
