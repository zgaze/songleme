.tabbar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  height: 112rpx;
  padding: 24rpx 56rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  border-radius: var(--r-lg) var(--r-lg) 0 0;
  box-shadow: 0 -24rpx 54rpx rgba(74, 48, 60, 0.10);
  box-sizing: content-box;
}

.tabbar__item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  margin: 0 12rpx;
  border-radius: var(--r-pill);
  color: var(--text-2);
  font-size: var(--fs-h1);
  font-weight: 600;
}

.tabbar__item--active {
  color: var(--on-blue);
  background: var(--blue-deep);
  font-weight: 800;
  box-shadow: var(--out-sm), var(--ins-blue);
}
