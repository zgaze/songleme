.result-card {
  position: relative;
  width: 100%;
  min-height: 348rpx;
  padding: 10rpx 8rpx 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: var(--r-md);
  background: var(--surface);
  color: var(--text);
  box-sizing: border-box;
  box-shadow: var(--out-lg), var(--ins-neutral);
}

.result-card__media {
  position: relative;
  width: 174rpx;
  height: 174rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: var(--r-sm);
  background: var(--blue);
  box-shadow: var(--ins-blue);
}

.result-card__image,
.result-card__image-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.result-card__image-placeholder::before {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.38);
  content: "";
}

.result-card__body {
  width: 100%;
  margin-top: 10rpx;
  padding: 0 4rpx;
  box-sizing: border-box;
  text-align: center;
}

.result-card--tone-0 .result-card__media {
  background: var(--blue);
  box-shadow: var(--ins-blue);
}

.result-card--tone-1 .result-card__media {
  background: var(--rose);
  box-shadow: var(--ins-rose);
}

.result-card--tone-2 .result-card__media {
  background: var(--gold);
  box-shadow: var(--ins-gold);
}

.result-card--tone-3 .result-card__media {
  background: var(--mint);
  box-shadow: var(--ins-mint);
}

.result-card__name {
  display: block;
  color: var(--text);
  font-size: var(--fs-label);
  font-weight: 600;
  line-height: 1.2;
  overflow-wrap: break-word;
}

.result-card__reason {
  display: -webkit-box;
  margin-top: 8rpx;
  overflow: hidden;
  color: var(--text-3);
  font-size: var(--fs-cap);
  font-weight: 500;
  line-height: 1.34;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.result-card__tags {
  min-height: 32rpx;
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 6rpx;
  overflow: hidden;
}

.result-card__tag {
  max-width: 96rpx;
  height: 32rpx;
  padding: 0 10rpx;
  border-radius: var(--r-pill);
  background: var(--blue-soft);
  color: var(--on-blue);
  box-sizing: border-box;
  font-size: var(--fs-cap);
  font-weight: 500;
  line-height: 32rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.result-card__share {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 42rpx;
  height: 42rpx;
  margin: 0;
  padding: 0;
  border-radius: var(--r-pill);
  background: var(--surface);
  line-height: 42rpx;
  box-shadow: var(--out-sm), var(--ins-neutral);
}

.result-card__share::after {
  border: 0;
}

.result-card__share-icon {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  margin: 7rpx auto 0;
}

.result-card__share-dot {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(27, 35, 43, 0.5);
}

.result-card__share-dot--left {
  left: 2rpx;
  top: 10rpx;
}

.result-card__share-dot--top {
  right: 2rpx;
  top: 2rpx;
}

.result-card__share-dot--bottom {
  right: 2rpx;
  bottom: 2rpx;
}

.result-card__share-line {
  position: absolute;
  left: 9rpx;
  width: 16rpx;
  height: 3rpx;
  border-radius: var(--r-pill);
  background: rgba(27, 35, 43, 0.36);
  transform-origin: left center;
}

.result-card__share-line--top {
  top: 11rpx;
  transform: rotate(-24deg);
}

.result-card__share-line--bottom {
  top: 15rpx;
  transform: rotate(24deg);
}
